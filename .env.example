# IsoBloom Environment Variables
# Copy this file to .env and fill in values as needed.
# .env is gitignored — never commit secrets.

# App metadata (optional, consumed via import.meta.env in Vite)
VITE_APP_TITLE="IsoBloom: The Flower Garden"
VITE_APP_VERSION="1.0.0"

# Future API integrations (leaderboard, etc.) would go here, e.g.:
# VITE_API_BASE_URL=https://api.example.com
# VITE_LEADERBOARD_KEY=your_key_here
